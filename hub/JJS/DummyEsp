local workspace = game:GetService("Workspace")

-- Setup paths
local charactersFolder = workspace:WaitForChild("Characters")
local dummy = charactersFolder:WaitForChild("Dummy")

-- Names for our tracker and highlight
local MARKER_NAME = "ToggleMarker"
local HIGHLIGHT_NAME = "DummyHighlight"

-- Check if the marker already exists
local existingMarker = dummy:FindFirstChild(MARKER_NAME)
local existingHighlight = dummy:FindFirstChild(HIGHLIGHT_NAME)

if existingMarker then
    -- STATE: ON -> Turn it OFF
    print("Toggle: Turning OFF")
    
    existingMarker:Destroy()
    if existingHighlight then
        existingHighlight:Destroy()
    end
else
    -- STATE: OFF -> Turn it ON
    print("Toggle: Turning ON")
    
    -- 1. Create the Marker Part (The flag)
    local marker = Instance.new("Part")
    marker.Name = MARKER_NAME
    marker.Transparency = 1 
    marker.CanCollide = false 
    marker.Size = Vector3.new(1, 1, 1)
    marker.Parent = dummy
    
    -- 2. Create the Highlight
    local highlight = Instance.new("Highlight")
    highlight.Name = HIGHLIGHT_NAME
    highlight.FillColor = Color3.fromRGB(255, 0, 0)
    highlight.OutlineColor = Color3.fromRGB(255, 255, 255)
    highlight.FillTransparency = 0.5
    highlight.OutlineTransparency = 0
    highlight.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
    highlight.Parent = dummy
end
