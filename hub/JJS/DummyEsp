-- CONFIGURATION
local isHighlightEnabled = true -- Change this to false to turn it off

-- SETUP
local workspace = game:GetService("Workspace")

-- We look for the folder first, then the dummy inside it
local charactersFolder = workspace:WaitForChild("Characters")
local dummy = charactersFolder:WaitForChild("Dummy")

local function updateHighlight()
    -- Look for an existing highlight inside the dummy
    local existingHighlight = dummy:FindFirstChild("DummyHighlight")

    if isHighlightEnabled then
        -- Only create if it doesn't already exist
        if not existingHighlight then
            local highlight = Instance.new("Highlight")
            highlight.Name = "DummyHighlight"
            highlight.FillColor = Color3.fromRGB(255, 0, 0) -- Red
            highlight.OutlineColor = Color3.fromRGB(255, 255, 255) -- White
            highlight.FillTransparency = 0.5
            highlight.OutlineTransparency = 0
            highlight.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
            highlight.Parent = dummy
        end
    else
        -- Remove the highlight if it exists
        if existingHighlight then
            existingHighlight:Destroy()
        end
    end
end

-- Run the logic
updateHighlight()
